@article{chy2025coolingtower,
  abbr={J. Build. Rehabil.},
  bibtex_show={true},
  title={Dynamic analysis of cooling tower considering two different column modeling approaches},
  author={Chy, Intekhab Uddin Ahmad and Fardin, Md Asadullahil Galib and Awall, Md Robiul and Biswas, Anik},
  journal={Journal of Building Pathology and Rehabilitation},
  volume={10},
  pages={120},
  year={2025},
  publisher={Springer},
  doi={10.1007/s41024-025-00632-6},
  html={https://doi.org/10.1007/s41024-025-00632-6},
  abstract={Nuclear power plants use cooling towers, which are frequently hyperboloid in shape, to disperse excess heat created during power generation. In this study, two models of a hyperbolic natural draught cooling tower were made — one with Embedded Reinforcement Columns and another with Simplified Columns modelled as Timoshenko Beam-type members. Both models were exposed to seismic and wind excitations and their responses were compared. The Embedded Reinforcement Column model exhibited greater flexibility and reduced stiffness, resulting in lower natural frequencies and larger displacements under both loads. The findings are relevant given Bangladesh's increased seismic susceptibility near the Madhupur Fault and the Rooppur Nuclear Power Plant.},
  keywords={Cooling tower, Conventional shell, Abaqus, Modal analysis, Nonlinear time history analysis},
  selected={true}
}
