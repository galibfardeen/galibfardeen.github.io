@article{afroz2025upvc,
  abbr={},
  bibtex_show={true},
  title={Impact Behavior of Pressurized uPVC Pipe: An Experimental and Numerical Analysis},
  author={Afroz, M. R. and Ahmed, T. U. and Fardin, Md Asadullahil Galib and Bashar, J. B. and Ahmed, H. and Raphi, S. H. and Akhi, A. H.},
  year={2025},
  note={Submitted},
  abstract={This study experimentally and numerically investigates the low-velocity lateral impact response of water-pressurised uPVC pipes under two support conditions — both-ends-clamped and one-clamped-one-roller — at four drop heights. A locally developed ESP32-based pressure and velocity measuring unit recorded internal pressure fluctuations in real time. Clamped supports produced up to 6.34% higher peak contact force. Internal pressure spikes reached 3063 kPa and grew with impact energy. Plastic deformation zones expanded radially with drop height. ABAQUS FEA results matched experimental data within approximately 14%.},
  keywords={uPVC pipe; low-velocity impact; internal pressure; support condition; FEA; ABAQUS},
  selected={true}
}

@article{islam2025cfrp,
  abbr={Adv. Civil Eng.},
  bibtex_show={true},
  title={Numerical Investigation on Behavior of CFRP Strengthened Beam-Column Steel Joint under Compressive and Cyclic Loading},
  author={Islam, Kazi Rashadul and Fardin, Md Asadullahil Galib},
  journal={Advances in Civil Engineering},
  year={2025},
  note={Under Review},
  abstract={This study investigates the behavior of CFRP-strengthened mild steel beam-column T-joints under monotonic and cyclic loading using ABAQUS finite element analysis. Three section profiles (Square, I-section, Circular Hollow) were modelled with and without CFRP retrofitting. CFRP strengthening improved load-carrying capacity by up to 26.71% under monotonic loading and enhanced energy dissipation by up to 33.20% under cyclic loading, demonstrating significant seismic performance gains.},
  keywords={CFRP; steel T-joints; cyclic loading; monotonic loading; ABAQUS; seismic strengthening},
  selected={true}
}

@article{chy2025coolingtower,
  abbr={J. Build. Rehabil.},
  bibtex_show={true},
  title={Dynamic analysis of cooling tower considering two different column modeling approaches},
  author={Chy, Intekhab Uddin Ahmad and Fardin, Md Asadullahil Galib and Awall, Md Robiul and Biswas, Anik},
  journal={Journal of Building Pathology and Rehabilitation},
  volume={10},
  pages={120},
  year={2025},
  publisher={Springer},
  doi={10.1007/s41024-025-00632-6},
  html={https://doi.org/10.1007/s41024-025-00632-6},
  abstract={Nuclear power plants use cooling towers, which are frequently hyperboloid in shape, to disperse excess heat created during power generation. In this study, two models of a hyperbolic natural draught cooling tower were made — one with Embedded Reinforcement Columns and another with Simplified Columns modelled as Timoshenko Beam-type members. Both models were exposed to seismic and wind excitations and their responses were compared. The Embedded Reinforcement Column model exhibited greater flexibility and reduced stiffness, resulting in lower natural frequencies and larger displacements under both loads. The findings are relevant given Bangladesh's increased seismic susceptibility near the Madhupur Fault and the Rooppur Nuclear Power Plant.},
  keywords={Cooling tower, Conventional shell, Abaqus, Modal analysis, Nonlinear time history analysis},
  selected={true}
}
