<div class="social-list">
  {% for social in site.data.socials %}
    {% case social[0] %}
      {% when 'email' %}
        <a href="mailto:{{ social[1] | encode_email }}" title="Email"><i class="fa-solid fa-envelope"></i></a>
      {% when 'facebook_id' %}
        <a href="https://facebook.com/{{ social[1] }}" target="_blank" title="Facebook"><i class="fa-brands fa-facebook"></i></a>
      {% when 'github_username' %}
        <a href="https://github.com/{{ social[1] }}" target="_blank" title="GitHub"><i class="fa-brands fa-github"></i></a>
      {% when 'linkedin_username' %}
        <a href="https://www.linkedin.com/in/{{ social[1] }}" target="_blank" title="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
      {% when 'orcid_id' %}
        <a href="https://orcid.org/{{ social[1] }}" target="_blank" title="ORCID"><i class="ai ai-orcid"></i></a>
      {% when 'scholar_userid' %}
        <a href="https://scholar.google.com/citations?user={{ social[1] }}" target="_blank" title="Google Scholar"><i class="ai ai-google-scholar"></i></a>
    {% endcase %}
  {% endfor %}
</div>
